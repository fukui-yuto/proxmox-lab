#!ipxe
dhcp

# MAC アドレスで answer.toml を切り替え
iseq ${net0/mac} f4:4d:30:69:2b:78 && set answer_url http://192.168.210.55/answer/node01.toml ||
iseq ${net0/mac} f4:4d:30:6c:67:ef && set answer_url http://192.168.210.55/answer/node02.toml ||
isset ${answer_url} || set answer_url http://192.168.210.55/answer/node01.toml

echo Booting Proxmox VE 8 Auto Install...
echo MAC: ${net0/mac}
echo Answer: ${answer_url}

kernel http://192.168.210.55/iso/boot/linux26 ro ramdisk_size=16777216 rw quiet splash=silent proxmox-start-auto-installer proxmox-answer-file=${answer_url}
initrd http://192.168.210.55/iso/boot/initrd-pxe.img
boot
